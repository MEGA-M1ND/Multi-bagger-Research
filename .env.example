# ---------------------------------------------------------------------------
# SNDK Detector Agent — configuration
# Copy to `.env` and fill in. Required keys are validated at startup.
# ---------------------------------------------------------------------------

# --- OpenAI (scoring) — REQUIRED ---
OPENAI_API_KEY=sk-...
# Model used for blueprint scoring + thesis generation. Default is cost-optimized.
OPENAI_MODEL=gpt-4o-mini

# --- Telegram (alerts) — REQUIRED ---
# Create a bot via @BotFather to get the token; get your chat id via @userinfobot.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# --- Scoring / dedup tuning — OPTIONAL (defaults shown) ---
# A candidate must score >= this (out of 6) to earn a thesis + alert.
BLUEPRINT_THRESHOLD=4
# Skip re-scoring candidates scored within this many days (saves tokens).
DEDUP_LOOKBACK_DAYS=7
# Cap on candidates pulled from each ingestion source per run.
MAX_CANDIDATES_PER_SOURCE=20
# Max simultaneous in-flight LLM calls (asyncio semaphore).
MAX_CONCURRENT_LLM=5

# --- Persistence — OPTIONAL ---
DB_PATH=sndk_detector.db

# --- SEC EDGAR — OPTIONAL but recommended ---
# SEC requires a descriptive User-Agent with contact info, or it returns 403.
# Format: "Sample Company Name AdminContact@example.com"
SEC_USER_AGENT=SNDK Detector your_email@example.com

# --- Perplexity enrichment — OPTIONAL (enables the `enrich` stage) ---
# If unset, the enrich stage is skipped and the agent runs as before. When set,
# each post-dedup candidate is grounded with structured financials + cited
# research before scoring. Requires api.perplexity.ai on the egress allowlist.
PERPLEXITY_API_KEY=pplx-...
# Perplexity model used for enrichment (sonar / sonar-pro / sonar-reasoning).
PERPLEXITY_MODEL=sonar
# Skip re-enriching candidates enriched within this many days (saves cost).
RESEARCH_LOOKBACK_DAYS=7
# Hard cap on Perplexity-enriched candidates per run (cost control).
MAX_ENRICH_PER_RUN=20
