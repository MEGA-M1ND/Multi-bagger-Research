# ---------------------------------------------------------------------------
# SNDK Detector Agent — configuration
# Copy to `.env` and fill in. Required keys are validated at startup.
# ---------------------------------------------------------------------------

# --- OpenAI (event classification, evidence extraction, memo) — REQUIRED ---
OPENAI_API_KEY=sk-...
# Model used for classification / extraction / memo + critic. Default is cost-optimized.
OPENAI_MODEL=gpt-4o-mini

# --- Telegram (alerts) — REQUIRED ---
# Create a bot via @BotFather to get the token; get your chat id via @userinfobot.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# --- Scoring tiers (0-100) — OPTIONAL (defaults shown) ---
# A candidate routes to the highest tier it clears. Telegram alerts fire only
# for deep_dive / starter. Must satisfy 0 <= watchlist <= deep_dive <= starter <= 100.
TIER_WATCHLIST=40
TIER_DEEP_DIVE=60
TIER_STARTER=75

# --- Dedup / throughput — OPTIONAL (defaults shown) ---
# Skip re-scoring candidates scored within this many days (saves tokens).
DEDUP_LOOKBACK_DAYS=7
# Cap on candidates pulled from each ingestion source per run.
MAX_CANDIDATES_PER_SOURCE=20
# Max simultaneous in-flight LLM calls (asyncio semaphore).
MAX_CONCURRENT_LLM=5

# --- Persistence / output — OPTIONAL ---
DB_PATH=sndk_detector.db
# Where deep-dive memos and the weekly watchlist are written.
OUTPUT_DIR=./output

# --- SEC EDGAR — OPTIONAL but recommended ---
# SEC requires a descriptive User-Agent with contact info, or it returns 403.
# Format: "Sample Company Name AdminContact@example.com"
SEC_USER_AGENT=SNDK Detector your_email@example.com

# --- Finnhub (news ingest) — OPTIONAL ---
# Free API key at https://finnhub.io — no credit card required.
# Without this, ingest_news returns no candidates.
FINNHUB_API_KEY=
